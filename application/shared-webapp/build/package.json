{
  "name": "@repo/build",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*.js",
    "./plugin/*": "./dist/plugin/*.js",
    "./react-env.d.ts": "./react-env.d.ts",
    "./module-federation-types/*.d.ts": "./module-federation-types/*.d.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf ./dist && tsc -b . environment",
    "check": "oxfmt --check && oxlint",
    "dev": "tsc -b . environment -w",
    "dev:setup": "tsc -b . environment",
    "format": "oxfmt && (oxlint --fix || true)",
    "lint": "oxlint"
  },
  "devDependencies": {
    "@repo/config": "*"
  }
}
