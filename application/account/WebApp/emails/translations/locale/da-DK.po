msgid "'{{'ProductName'}}' login verification code"
msgstr "'{{'ProductName'}}'-bekræftelseskode til login"

msgid "<0/> invited you to join '{{'ProductName'}}'."
msgstr "<0/> har inviteret dig til at deltage i '{{'ProductName'}}'."

msgid "<0/> replied to your ticket"
msgstr "<0/> har svaret på din sag"

msgid "Compliance"
msgstr "Compliance"

msgid "Confirm your email address"
msgstr "Bekræft din e-mailadresse"

msgid "DPA"
msgstr "DPA"

msgid "Enter it in your open browser window. It is only valid for a few minutes."
msgstr "Indtast den i dit åbne browservindue. Den er kun gyldig i få minutter."

msgid "Here's your new verification code"
msgstr "Her er din nye bekræftelseskode"

msgid "If this wasn't you, no action is needed — no account was created."
msgstr "Hvis det ikke var dig, behøver du ikke gøre noget — der blev ikke oprettet en konto."

msgid "If you didn't request a new code, you can safely ignore this email."
msgstr "Hvis du ikke har anmodet om en ny kode, kan du roligt ignorere denne e-mail."

msgid "If you didn't request to sign up, you can safely ignore this email."
msgstr "Hvis du ikke har anmodet om at oprette en konto, kan du roligt ignorere denne e-mail."

msgid "If you didn't try to log in, you can safely ignore this email — your account is secure."
msgstr "Hvis du ikke har forsøgt at logge ind, kan du roligt ignorere denne e-mail — din konto er sikker."

msgid "If you don't recognize the sender, you can safely ignore this email."
msgstr "Hvis du ikke kender afsenderen, kan du roligt ignorere denne e-mail."

msgid "Is this the right email address?"
msgstr "Er det den rigtige e-mailadresse?"

msgid "It looks like there isn't a '{{'ProductName'}}' account tied to <0><1/></0>."
msgstr "Det ser ud til, at der ikke er en '{{'ProductName'}}'-konto knyttet til <0><1/></0>."

msgid "No account found"
msgstr "Ingen konto fundet"

msgid "Open ticket"
msgstr "Åbn sagen"

msgid "Privacy"
msgstr "Privatliv"

msgid "Re: '{{'Subject'}}' · #'{{'ShortDisplayId'}}'"
msgstr "Sv: '{{'Subject'}}' · #'{{'ShortDisplayId'}}'"

msgid "Reply by opening the ticket — replies to this email are not monitored."
msgstr "Svar ved at åbne sagen — svar på denne e-mail bliver ikke læst."

msgid "Sign up for an account"
msgstr "Opret en konto"

msgid "Terms"
msgstr "Vilkår"

msgid "This code will expire in a few minutes."
msgstr "Denne kode udløber om få minutter."

msgid "To gain access, <0>go to this page in your open browser</0> and login using <1><2/></1>."
msgstr "For at få adgang skal du <0>gå til denne side i din åbne browser</0> og logge ind med <1><2/></1>."

msgid "We're sending this code again as you requested."
msgstr "Vi sender denne kode igen, som du anmodede om."

msgid "You can try again with a different email, or sign up for a new account."
msgstr "Du kan prøve igen med en anden e-mailadresse eller oprette en ny konto."

msgid "You have been invited to join '{{'TenantName'}}' on '{{'ProductName'}}'"
msgstr "Du er inviteret til at deltage i '{{'TenantName'}}' på '{{'ProductName'}}'"

msgid "Your confirmation code is below"
msgstr "Din bekræftelseskode står herunder"

msgid "Your verification code (resend)"
msgstr "Din bekræftelseskode (gensendt)"
